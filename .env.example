# Example values for the CONFIG block in YouTube_to_Doc.gs
# Copy these into the CONFIG object — do NOT commit your real values.
# For production, prefer PropertiesService.getScriptProperties() instead of hard-coding.

CLAUDE_API_KEY=sk-ant-...                            # https://console.anthropic.com
NETLIFY_TOKEN=nfp_...                                # https://app.netlify.com/user/applications
NETLIFY_SITE=my-yt-summaries                         # the slug, e.g. my-yt-summaries.netlify.app
EMAIL_TO=you@example.com                             # where owner notifications go
SUPADATA_KEY=sd_...                                  # https://supadata.ai
DRIVE_FOLDER_ID=1AbC...                              # optional Drive folder for HTML backups
STATIC_PAGES_FOLDER_ID=1AbC...                       # Drive folder with about.html, casestudy, etc.
WEBAPP_URL=https://script.google.com/.../exec        # fill after "Deploy as Web App"
ADMIN_CODE=long-random-string-not-a-word             # used to authorize deletions — keep secret
